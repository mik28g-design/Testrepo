        private bool IsMarkerPresentInLine(MarkerDef marker, string line)
        {
            if (string.IsNullOrWhiteSpace(line))
            {
                return false;
            }

            if (marker.IsPipe)
            {
                // Spezielle Pipe-Logik: Suche eine Pipe, die das letzte sichtbare Zeichen 
                // einer visuellen Zeile ist (vor einem \v oder dem String-Ende).
                int pipeIdx = line.IndexOf('|');
                while (pipeIdx >= 0)
                {
                    int nextVt = line.IndexOf('\v', pipeIdx + 1);

                    string segmentAfterPipe = (nextVt >= 0)
                        ? line.Substring(pipeIdx + 1, nextVt - (pipeIdx + 1))
                        : line.Substring(pipeIdx + 1);

                    if (segmentAfterPipe.Trim().Length == 0)
                    {
                        return true;
                    }

                    pipeIdx = line.IndexOf('|', pipeIdx + 1);
                }
                return false;
            }

            // Für alle anderen Marker suchen wir im gesamten String
            if (marker.IsRegex)
            {
                return Regex.IsMatch(line, marker.SearchPattern);
